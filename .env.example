# ──────────────────────────────────────────────────────────────
# El Bayt El Djazairi — environment variables
# Copy this file to ".env.local" and fill in the values.
# The site runs WITHOUT these (orders fall back to WhatsApp only).
# Add the Supabase keys to start saving leads/orders to the database.
# ──────────────────────────────────────────────────────────────

# WhatsApp number that receives orders (international format, digits only, no "+").
NEXT_PUBLIC_WHATSAPP_PHONE=213770040474

# Public site URL (used for SEO canonical / Open Graph / sitemap).
NEXT_PUBLIC_SITE_URL=https://elbayt-eldjazairi.vercel.app

# ── Supabase (optional but recommended) ──
# Project URL + anon (public) key from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never expose to the browser, never commit.
# Used by the API routes to insert orders/requests past Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin panel (/admin) ──
# Password to log into /admin. Required to use the admin panel.
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie. Use a long random string.
# Falls back to ADMIN_PASSWORD if left empty.
ADMIN_SESSION_SECRET=
